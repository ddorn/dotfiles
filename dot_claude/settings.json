{
  "permissions": {
    "allow": [
      "Bash(~/.config/ranger/scope.sh:*)",
      "Bash(ls:*)",
      "Bash(systemctl status:*)",
      "Bash(pacman:*)",
      "Bash(journalctl:*)",
      "Bash(echo:*)",
      "Bash(virsh net-list:*)",
      "Bash(virsh version:*)",
      "Bash(virsh:*)",
      "Bash(tree:*)",
      "Bash(swaymsg:*)"
    ],
    "ask": [
      "Bash(rm:*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' 'Ready for input'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' \"$( cat - | jq -r '.message' )\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/diego/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "claude-code-wakatime@wakatime": true,
    "frontend-design@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "editorMode": "vim",
  "voiceEnabled": true
}
