backup_snooze_file=.cache/backups/dont_ask_for_backup_until  # e.g. 2024-12-28T19:00:22.950168
# If snoozed, don't run the backup script. The script updates this file when needed.
# The file may not exist or be empty, in which case the backup will run.
if [ -f $backup_snooze_file ] && [ $(date -d $(cat $backup_snooze_file) +%s) -gt $(date +%s) ]; then
    # echo "Backup snoozed until $(cat $backup_snooze_file)"
else
    # Don't run backup if CURSOR_AGENT=1 (in the cursor agent)
    if [ "$CURSOR_AGENT" != "1" ]; then
        ~/.config/restic/backup.py backup --if-needed
    fi
fi

# Check if /home is low on disk space (<= 500Mb)
