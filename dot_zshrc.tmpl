compress-mp4 () {
    ffmpeg -i "$1" -vcodec libx265 -crf 28 "compressed-$1"
}

{{- if hasSuffix "laptop" .role }}
# Mirror current output to the other monitor
mirror() {
    focused_output=$(swaymsg -t get_outputs | jq -r '.[] | select(.focused) | .name')
    other_output=$(swaymsg -t get_outputs | jq -r --arg focused "$focused_output" '.[] | select(.name != $focused) | .name' | head -n 1)
    if [ -z "$other_output" ]; then
        echo "No other output found"
        return
    fi
    wl-mirror $focused_output &!
    sleep 0.5
    swaymsg '[app_id="wl_mirror"]' move output $other_output
    swaymsg '[app_id="wl_mirror"]' fullscreen
}
{{- end }}


