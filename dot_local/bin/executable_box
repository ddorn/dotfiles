#!/usr/bin/env bash
# box — run Claude Code (or any command) inside a bubblewrap sandbox
# scoped to the current working directory.
#
# What's visible inside the sandbox:
#   /usr /etc /opt /var /sys      read-only  — system software, certs, resolv.conf
#   $PWD (the project you cd'd to) read-write — your project files
#   ~/.local/bin                  read-only  — user-installed CLIs (claude, etc.)
#   ~/.local/share/claude         read-only  — Claude Code runtime
#   ~/.cache/uv                   read-write — uv package cache (shared across projects)
#   ~/.claude  +  ~/.claude.json  read-write — Claude config / sessions / OAuth token
#   ~/.gitconfig + ~/.config/git  read-only  — git author identity for commits
#
# What's INVISIBLE: everything else under $HOME — ~/.ssh, other project
# directories, browser profiles, ~/.aws, ~/.gnupg, dotfiles, etc.
#
# Usage:
#   cd ~/prog/some-project
#   box                   # launches `claude` in the sandbox
#   box bash              # interactive shell instead
#   box uv run pytest     # one-shot command
#
# ─── HOW TO EXTEND ──────────────────────────────────────────────────────────
# • Expose another tool's cache/config:        add a `maybe_bind` line below.
#     - read-only:  maybe_ro_bind "$H/.config/gh"
#     - read-write: maybe_bind    "$H/.cache/pip"
# • Expose a sibling project (read-only ref):  maybe_ro_bind "$H/prog/lib-x"
# • Cut network access (offline mode):         add `--unshare-net \` to the bwrap call.
# • Block writes to uv cache / ~/.claude:      change `maybe_bind` → `maybe_ro_bind`.
# • Pass an env var through from outside:      add `--setenv NAME "$NAME" \`.
# • Persist work to a scratch dir outside cwd: add `--bind ~/scratch ~/scratch \`.
# • Per-project override: drop a `.box` file at the repo root with extra
#   bwrap flags, one per line — sourced near the bottom of this script.
# ────────────────────────────────────────────────────────────────────────────

set -euo pipefail

if ! command -v bwrap >/dev/null; then
  echo "box: bwrap not found — install bubblewrap" >&2
  exit 1
fi

PROJECT="$(realpath $PWD)"
H="${HOME}"

# Refuse to run if cwd is $HOME itself or somewhere that would expose too much.
case "$PROJECT" in
  "$H"|"$H/"|/|"")
    echo "box: refusing to sandbox \$HOME or / — cd into a project first." >&2
    exit 1
    ;;
esac

binds=(
  # System software & config (read-only).
  --ro-bind /usr /usr
  --ro-bind /etc /etc
  --ro-bind /opt /opt
  --ro-bind /var /var
  --ro-bind /sys /sys
  --symlink usr/bin /bin
  --symlink usr/bin /sbin
  --symlink usr/lib /lib
  --symlink usr/lib /lib64

  # Kernel-provided pseudo-filesystems.
  --proc /proc
  --dev /dev
  --tmpfs /tmp
  --tmpfs /run

  # Empty home, then graft only what we want into it.
  --tmpfs "$H"

  # The project itself: read-write.
  --bind "$PROJECT" "$PROJECT"
)

# Helpers — only mount if the source exists, so missing tools don't break the script.
maybe_ro_bind() { if [[ -e "$1" ]]; then binds+=(--ro-bind "$1" "$1"); else echo "box: skipping missing path: $1" >&2; fi; }
maybe_bind()    { if [[ -e "$1" ]]; then binds+=(--bind    "$1" "$1"); else echo "box: skipping missing path: $1" >&2; fi; }

# ─── ADD/REMOVE EXPOSED PATHS HERE ──────────────────────────────────────────
maybe_ro_bind "$H/.local/bin"
maybe_ro_bind "$H/.local/share/claude"
maybe_bind    "$H/.claude"
maybe_bind    "$H/.claude.json"
maybe_ro_bind "$H/.streamlit"
maybe_ro_bind "$H/.wakatime.cfg"
maybe_bind    "$H/.cache/uv"
maybe_bind    "$H/.cache/ephemeral-cache"
maybe_bind    "$H/.cache/pre-commit/"
maybe_bind    "$H/.cache/mesa_shader_cache"
maybe_bind    "$H/.config/Code - OSS"
maybe_bind    "$H/.config/Cursor"
maybe_bind    "$H/.vscode-oss"
maybe_bind    "$H/.cursor"
maybe_ro_bind "$H/.gitconfig"
maybe_ro_bind "$H/.config/git"
maybe_ro_bind "$H/.config/uv"
maybe_ro_bind "$H/.local/share/uv/python"

# direnv allow/deny approvals — so .envrc loaded by direnv inside the box is
# recognized as already-allowed (read-only: approve outside the box).
maybe_ro_bind "$H/.local/share/direnv"
maybe_ro_bind "$H/.local/share/pnpm"

# Interactive zsh config (read-only — config, not data). Lets `box zsh`
# reuse your oh-my-zsh / starship / aliases setup. History stays ephemeral
# (written to the tmpfs $HOME and discarded on exit) on purpose.
maybe_ro_bind "$H/.zshrc"
maybe_ro_bind "$H/.zshenv"
maybe_ro_bind "$H/.config/shell"
maybe_ro_bind "$H/.config/starship.toml"
maybe_ro_bind "$H/.oh-my-zsh"
maybe_ro_bind "$H/.zfunc"


if [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
    maybe_bind "$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY"
fi

# ────────────────────────────────────────────────────────────────────────────

# Per-project extension: a `.box` file at the repo root can append
# extra bwrap flags (one token per line, '#'-comments allowed). Example:
#     --ro-bind
#     /home/diego/prog/shared-lib
#     /home/diego/prog/shared-lib
extra=()
if [[ -f "$PROJECT/.box" ]]; then
  while IFS= read -r line; do
    [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
    extra+=("$line")
  done < "$PROJECT/.box"
fi

# Default command: run claude. Override by passing args (e.g. `box bash`).
if [[ $# -eq 0 ]]; then
  set -- claude
fi

exec bwrap \
  "${binds[@]}" \
  "${extra[@]}" \
  --setenv TERM "${TERM:-xterm-256color}" \
  --setenv PS1 '(box) \w \$ ' \
  --setenv SKIP_DD_BACKUP 1 \
  `# ^ makes ~/.config/shell/common.sh skip its auto-backup on shell startup` \
  --setenv BOX_PROJECT "$(basename "$PROJECT")" \
  `# ^ marker the prompt reads to show "(box-<project>)"` \
  --unsetenv SWAYSOCK \
  `# ^ The sway IPC socket lives under /run (tmpfs is mounted over it here),` \
  `#   so the inherited SWAYSOCK is stale: drop it, else swaymsg clients` \
  `#   (e.g. the bgnotify zsh plugin) spam connection errors every prompt.` \
  `#   Do NOT bind the socket to fix this. The sway IPC has an exec verb and` \
  `#   sway runs OUTSIDE the sandbox, so swaymsg exec sh -c ... would spawn` \
  `#   arbitrary commands on the host with your full privileges: a complete` \
  `#   sandbox escape. Keeping it unset is the whole point.` \
  --chdir "$PROJECT" \
  --unshare-user \
  --unshare-ipc \
  --unshare-pid \
  --unshare-uts \
  --die-with-parent \
  "$@"
